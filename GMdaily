<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>TempoGM | Your Daily Web3 Ritual on Tempo</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    :root {
      --bg: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      --card-bg: rgba(255, 255, 255, 0.1);
      --card-border: rgba(255, 255, 255, 0.18);
      --accent: #00d4ff;
      --accent-glow: rgba(0, 212, 255, 0.4);
      --text-main: #ffffff;
      --text-soft: rgba(255, 255, 255, 0.8);
      --success: #00ff88;
      --danger: #ff4757;
      --warning: #ffa502;
      --glass: backdrop-filter: blur(20px);
      --shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      background-attachment: fixed;
      color: var(--text-main);
      min-height: 100vh;
      overflow-x: hidden;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }

    /* Header */
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 0;
      margin-bottom: 40px;
      flex-wrap: wrap;
      gap: 20px;
    }

    .logo {
      font-size: 28px;
      font-weight: 800;
      background: linear-gradient(45deg, var(--accent), #00ff88);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .wallet-section {
      display: flex;
      gap: 15px;
      align-items: center;
      flex-wrap: wrap;
    }

    .network-badge {
      padding: 8px 16px;
      background: var(--card-bg);
      var(--glass);
      border: 1px solid var(--card-border);
      border-radius: 25px;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
    }

    .btn {
      padding: 12px 24px;
      border: none;
      border-radius: 25px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 14px;
    }

    .btn-primary {
      background: linear-gradient(45deg, var(--accent), #00ff88);
      color: #000;
      box-shadow: 0 4px 15px var(--accent-glow);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px var(--accent-glow);
    }

    .btn-secondary {
      background: transparent;
      color: var(--text-main);
      border: 2px solid var(--card-border);
    }

    .btn-secondary:hover {
      background: var(--card-bg);
      var(--glass);
    }

    .btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none !important;
    }

    /* Main Grid */
    .main-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 30px;
      margin-bottom: 40px;
    }

    @media (max-width: 768px) {
      .main-grid { grid-template-columns: 1fr; }
    }

    /* Glass Cards */
    .glass-card {
      background: var(--card-bg);
      var(--glass);
      border: 1px solid var(--card-border);
      border-radius: 20px;
      padding: 30px;
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
    }

    .glass-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
    }

    .card-title {
      font-size: 24px;
      font-weight: 700;
      margin-bottom: 10px;
      background: linear-gradient(45deg, var(--text-main), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .card-subtitle {
      color: var(--text-soft);
      margin-bottom: 25px;
      line-height: 1.6;
    }

    /* GM Section */
    .gm-section {
      text-align: center;
    }

    .gm-button {
      width: 200px;
      height: 200px;
      border-radius: 50%;
      border: none;
      background: linear-gradient(135deg, var(--accent), #00ff88, #667eea);
      color: #000;
      font-size: 48px;
      font-weight: 900;
      cursor: pointer;
      transition: all 0.3s ease;
      margin: 20px auto;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    .gm-button::before {
      content: '';
      position: absolute;
      inset: -2px;
      background: linear-gradient(45deg, var(--accent), #00ff88, #667eea, var(--accent));
      border-radius: 50%;
      z-index: -1;
      animation: rotate 3s linear infinite;
    }

    .gm-button:hover {
      transform: scale(1.05);
      box-shadow: 0 10px 40px var(--accent-glow);
    }

    .gm-button:disabled {
      opacity: 0.7;
      cursor: not-allowed;
      transform: none !important;
    }

    @keyframes rotate {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .fee-info {
      background: rgba(255, 165, 2, 0.1);
      border: 1px solid var(--warning);
      border-radius: 15px;
      padding: 15px;
      margin-top: 20px;
      font-size: 14px;
    }

    /* Deploy Section */
    .deploy-form {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .form-label {
      font-weight: 600;
      font-size: 14px;
    }

    .form-input, .form-select {
      padding: 15px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid var(--card-border);
      border-radius: 12px;
      color: var(--text-main);
      font-size: 16px;
      transition: all 0.3s ease;
    }

    .form-input:focus, .form-select:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(0, 212, 255, 0.1);
    }

    .form-input::placeholder {
      color: var(--text-soft);
    }

    /* Stats Section */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: 20px;
      margin-top: 40px;
    }

    .stat-card {
      background: var(--card-bg);
      var(--glass);
      border: 1px solid var(--card-border);
      border-radius: 15px;
      padding: 20px;
      text-align: center;
    }

    .stat-number {
      font-size: 32px;
      font-weight: 800;
      color: var(--accent);
      display: block;
    }

    .stat-label {
      font-size: 12px;
      color: var(--text-soft);
      text-transform: uppercase;
      margin-top: 5px;
    }

    /* Status Messages */
    .status {
      padding: 15px 20px;
      border-radius: 12px;
      margin-top: 20px;
      font-weight: 500;
      text-align: center;
    }

    .status.success {
      background: rgba(0, 255, 136, 0.1);
      border: 1px solid var(--success);
      color: var(--success);
    }

    .status.error {
      background: rgba(255, 71, 87, 0.1);
      border: 1px solid var(--danger);
      color: var(--danger);
    }

    .status.pending {
      background: rgba(0, 212, 255, 0.1);
      border: 1px solid var(--accent);
      color: var(--accent);
    }

    .tx-link {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
    }

    .tx-link:hover {
      text-decoration: underline;
    }

    /* Activity Feed */
    .activity-feed {
      max-height: 300px;
      overflow-y: auto;
      margin-top: 20px;
    }

    .activity-item {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--card-border);
      border-radius: 12px;
      padding: 15px;
      margin-bottom: 10px;
      font-size: 14px;
    }

    .activity-time {
      color: var(--text-soft);
      font-size: 12px;
    }

    /* Responsive */
    @media (max-width: 480px) {
      .container { padding: 15px; }
      .gm-button { width: 150px; height: 150px; font-size: 36px; }
      .main-grid { gap: 20px; }
      .glass-card { padding: 20px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <div class="header">
      <div class="logo">
        🌅 TempoGM
      </div>
      <div class="wallet-section">
        <div class="network-badge" id="networkStatus">Tempo Moderato</div>
        <button class="btn btn-primary" id="connectBtn">Connect Wallet</button>
        <button class="btn btn-secondary" id="disconnectBtn" style="display: none;">Disconnect</button>
      </div>
    </div>

    <!-- Main Content -->
    <div class="main-grid">
      <!-- GM Section -->
      <div class="glass-card gm-section">
        <h2 class="card-title">Send Your Daily GM</h2>
        <p class="card-subtitle">Join the Tempo community in sending your daily Web3 ritual message on-chain</p>
        
        <button class="gm-button" id="gmBtn" disabled>
          GM
        </button>
        
        <div class="fee-info">
          📋 Fee: 10 <select id="feeTokenSelect" style="background:transparent;border:none;color:inherit;font-weight:bold;">
            <option value="pathUSD">pathUSD</option>
            <option value="AlphaUSD">AlphaUSD</option>
            <option value="BetaUSD">BetaUSD</option>
          </select>
        </div>

        <div id="gmStatus" class="status" style="display: none;"></div>
      </div>

      <!-- Deploy Section -->
      <div class="glass-card">
        <h2 class="card-title">Deploy Contract</h2>
        <p class="card-subtitle">Deploy your own smart contract on Tempo testnet</p>
        
        <div class="deploy-form">
          <div class="form-group">
            <label class="form-label">Contract Name</label>
            <input type="text" class="form-input" id="contractName" placeholder="My Awesome Contract">
          </div>
          
          <div class="form-group">
            <label class="form-label">Contract Type</label>
            <select class="form-select" id="contractType">
              <option value="token">ERC-20 Token</option>
              <option value="nft">ERC-721 NFT</option>
              <option value="simple">Simple Storage</option>
            </select>
          </div>
          
          <button class="btn btn-primary" id="deployBtn" disabled>Deploy Contract (10 tokens)</button>
        </div>

        <div id="deployStatus" class="status" style="display: none;"></div>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card">
        <span class="stat-number" id="totalGMs">0</span>
        <div class="stat-label">Total GMs</div>
      </div>
      <div class="stat-card">
        <span class="stat-number" id="todayGMs">0</span>
        <div class="stat-label">Today's GMs</div>
      </div>
      <div class="stat-card">
        <span class="stat-number" id="totalDeployments">0</span>
        <div class="stat-label">Contracts Deployed</div>
      </div>
      <div class="stat-card">
        <span class="stat-number" id="totalFees">0</span>
        <div class="stat-label">Total Fees Collected</div>
      </div>
    </div>

    <!-- Activity Feed -->
    <div class="glass-card" style="margin-top: 40px;">
      <h2 class="card-title">Recent Activity</h2>
      <div class="activity-feed" id="activityFeed">
        <div style="text-align: center; color: var(--text-soft); padding: 40px;">
          No activity yet. Connect your wallet to get started!
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/ethers/6.7.0/ethers.umd.min.js"></script>
  <script>
    // Configuration
    const TEMPO_CHAIN_ID = 42431;
    const TEMPO_CHAIN_HEX = '0xA5BF';
    const EXPLORER_URL = 'https://explore.tempo.xyz';
    
    // YOUR WALLET ADDRESS - Replace with your actual wallet address
    const FEE_RECIPIENT = '0xYourWalletAddressHere'; // 🚨 CHANGE THIS TO YOUR ADDRESS
    
    const TOKENS = {
      pathUSD: { address: '0x20c0000000000000000000000000000000000000', decimals: 6 },
      AlphaUSD: { address: '0x20c0000000000000000000000000000000000001', decimals: 6 },
      BetaUSD: { address: '0x20c0000000000000000000000000000000000002', decimals: 6 }
    };

    const TOKEN_ABI = [
      'function balanceOf(address owner) view returns (uint256)',
      'function transfer(address to, uint256 amount) returns (bool)',
      'function approve(address spender, uint256 amount) returns (bool)'
    ];

    // Contract bytecodes for deployment
    const CONTRACT_BYTECODES = {
      token: '...', // Simplified token bytecode
      nft: '0x608060405234801561001057600080fd5b50610140806100206000396000f3fe...',
      simple: '0x608060405234801561001057600080fd5b50610120806100206000396000f3fe...'
    };

    // State
    let provider, signer, userAddress;
    let stats = { totalGMs: 0, todayGMs: 0, totalDeployments: 0, totalFees: 0 };
    let lastGMTimestamp = 0;

    // DOM Elements
    const connectBtn = document.getElementById('connectBtn');
    const disconnectBtn = document.getElementById('disconnectBtn');
    const gmBtn = document.getElementById('gmBtn');
    const deployBtn = document.getElementById('deployBtn');
    const feeTokenSelect = document.getElementById('feeTokenSelect');
    const contractName = document.getElementById('contractName');
    const contractType = document.getElementById('contractType');
    const gmStatus = document.getElementById('gmStatus');
    const deployStatus = document.getElementById('deployStatus');
    const activityFeed = document.getElementById('activityFeed');

    // Utility Functions
    function showStatus(element, message, type = '', includeLink = false, hash = '') {
      element.style.display = 'block';
      element.className = `status ${type}`;
      
      let content = message;
      if (includeLink && hash) {
        content += ` <a href="${EXPLORER_URL}/tx/${hash}" target="_blank" class="tx-link">View on Explorer ↗</a>`;
      }
      element.innerHTML = content;
    }

    function hideStatus(element) {
      element.style.display = 'none';
    }

    function addActivity(message, hash = '') {
      const activity = document.createElement('div');
      activity.className = 'activity-item';
      
      let content = `<div>${message}</div>`;
      content += `<div class="activity-time">${new Date().toLocaleTimeString()}</div>`;
      if (hash) {
        content += `<a href="${EXPLORER_URL}/tx/${hash}" target="_blank" class="tx-link">View Transaction ↗</a>`;
      }
      
      activity.innerHTML = content;
      
      // Clear placeholder if it exists
      if (activityFeed.children[0] && activityFeed.children[0].style.textAlign === 'center') {
        activityFeed.innerHTML = '';
      }
      
      activityFeed.insertBefore(activity, activityFeed.firstChild);
    }

    function updateStats() {
      document.getElementById('totalGMs').textContent = stats.totalGMs;
      document.getElementById('todayGMs').textContent = stats.todayGMs;
      document.getElementById('totalDeployments').textContent = stats.totalDeployments;
      document.getElementById('totalFees').textContent = stats.totalFees;
    }

    function canSendGMToday() {
      const now = Date.now();
      const oneDayMs = 24 * 60 * 60 * 1000;
      return (now - lastGMTimestamp) >= oneDayMs;
    }

    // Wallet Functions
    async function connectWallet() {
      if (!window.ethereum) {
        showStatus(gmStatus, 'Please install MetaMask to continue', 'error');
        return;
      }

      try {
        showStatus(gmStatus, 'Connecting to wallet...', 'pending');
        
        provider = new ethers.BrowserProvider(window.ethereum);
        await provider.send('eth_requestAccounts', []);
        
        // Switch to Tempo network
        try {
          await window.ethereum.request({
            method: 'wallet_switchEthereumChain',
            params: [{ chainId: TEMPO_CHAIN_HEX }]
          });
        } catch (switchError) {
          if (switchError.code === 4902) {
            await window.ethereum.request({
              method: 'wallet_addEthereumChain',
              params: [{
                chainId: TEMPO_CHAIN_HEX,
                chainName: 'Tempo Moderato Testnet',
                rpcUrls: ['https://rpc.moderato.tempo.xyz'],
                nativeCurrency: { name: 'pathUSD', symbol: 'pUSD', decimals: 18 },
                blockExplorerUrls: [EXPLORER_URL]
              }]
            });
          } else throw switchError;
        }

        provider = new ethers.BrowserProvider(window.ethereum);
        signer = await provider.getSigner();
        userAddress = await signer.getAddress();

        // Update UI
        connectBtn.style.display = 'none';
        disconnectBtn.style.display = 'inline-flex';
        disconnectBtn.textContent = `${userAddress.slice(0, 6)}...${userAddress.slice(-4)}`;
        gmBtn.disabled = false;
        deployBtn.disabled = false;

        hideStatus(gmStatus);
        addActivity(`💎 Wallet connected: ${userAddress.slice(0, 6)}...${userAddress.slice(-4)}`);
        
      } catch (error) {
        showStatus(gmStatus, `Connection failed: ${error.message}`, 'error');
      }
    }

    function disconnectWallet() {
      provider = undefined;
      signer = undefined;
      userAddress = undefined;
      
      connectBtn.style.display = 'inline-flex';
      disconnectBtn.style.display = 'none';
      gmBtn.disabled = true;
      deployBtn.disabled = true;
      
      hideStatus(gmStatus);
      hideStatus(deployStatus);
      addActivity('👋 Wallet disconnected');
    }

    // GM Function
    async function sendGM() {
      if (!signer) {
        showStatus(gmStatus, 'Please connect your wallet first', 'error');
        return;
      }

      if (!canSendGMToday()) {
        showStatus(gmStatus, 'You can only send one GM per day! Come back tomorrow 🌅', 'error');
        return;
      }

      try {
        gmBtn.disabled = true;
        const selectedToken = feeTokenSelect.value;
        showStatus(gmStatus, 'Preparing to send GM...', 'pending');

        // Send fee to your wallet
        const tokenInfo = TOKENS[selectedToken];
        const feeAmount = ethers.parseUnits('10', tokenInfo.decimals);
        const tokenContract = new ethers.Contract(tokenInfo.address, TOKEN_ABI, signer);
        
        showStatus(gmStatus, 'Sending fee and GM message...', 'pending');
        const tx = await tokenContract.transfer(FEE_RECIPIENT, feeAmount);
        
        showStatus(gmStatus, 'Transaction sent! Waiting for confirmation...', 'pending');
        await tx.wait();

        // Update stats
        stats.totalGMs++;
        stats.todayGMs++;
        stats.totalFees += 10;
        lastGMTimestamp = Date.now();
        updateStats();

        showStatus(gmStatus, '🌅 GM sent successfully! Good morning, anon!', 'success', true, tx.hash);
        addActivity(`🌅 Sent daily GM (Fee: 10 ${selectedToken})`, tx.hash);

      } catch (error) {
        showStatus(gmStatus, `Failed to send GM: ${error.message}`, 'error');
      } finally {
        // Re-enable button after 24 hours or if error
        setTimeout(() => {
          if (canSendGMToday()) {
            gmBtn.disabled = false;
          }
        }, 1000);
      }
    }

    // Deploy Function
    async function deployContract() {
      if (!signer) {
        showStatus(deployStatus, 'Please connect your wallet first', 'error');
        return;
      }

      const name = contractName.value.trim();
      if (!name) {
        showStatus(deployStatus, 'Please enter a contract name', 'error');
        return;
      }

      try {
        deployBtn.disabled = true;
        const selectedToken = feeTokenSelect.value;
        showStatus(deployStatus, 'Preparing to deploy contract...', 'pending');

        // Send fee first
        const tokenInfo = TOKENS[selectedToken];
        const feeAmount = ethers.parseUnits('10', tokenInfo.decimals);
        const tokenContract = new ethers.Contract(tokenInfo.address, TOKEN_ABI, signer);
        
        showStatus(deployStatus, 'Sending deployment fee...', 'pending');
        const feeTx = await tokenContract.transfer(FEE_RECIPIENT, feeAmount);
        await feeTx.wait();

        // Deploy contract
        showStatus(deployStatus, 'Deploying your contract...', 'pending');
        const type = contractType.value;
        const bytecode = CONTRACT_BYTECODES[type];
        
        const deployTx = await signer.sendTransaction({
          data: bytecode,
          gasLimit: 500000
        });

        showStatus(deployStatus, 'Contract deployment sent! Waiting for confirmation...', 'pending');
        const receipt = await deployTx.wait();

        // Update stats
        stats.totalDeployments++;
        stats.totalFees += 10;
        updateStats();

        const contractAddress = receipt.contractAddress;
        showStatus(deployStatus, `🎉 Contract "${name}" deployed successfully!<br>Address: ${contractAddress}`, 'success', true, deployTx.hash);
        addActivity(`🚀 Deployed "${name}" contract (${type}) - Fee: 10 ${selectedToken}`, deployTx.hash);

        // Reset form
        contractName.value = '';

      } catch (error) {
        showStatus(deployStatus, `Deployment failed: ${error.message}`, 'error');
      } finally {
        deployBtn.disabled = false;
      }
    }

    // Event Listeners
    connectBtn.addEventListener('click', connectWallet);
    disconnectBtn.addEventListener('click', disconnectWallet);
    gmBtn.addEventListener('click', sendGM);
    deployBtn.addEventListener('click', deployContract);

    // Initialize
    updateStats();

    // Check GM availability every minute
    setInterval(() => {
      if (userAddress && canSendGMToday()) {
        gmBtn.disabled = false;
        gmBtn.textContent = 'GM';
      } else if (userAddress) {
        gmBtn.disabled = true;
        gmBtn.textContent = 'GM SENT';
      }
    }, 60000);
  </script>
</body>
</html>
